# Copy this file to .env and fill in the values.

# Password to log in to the app
AUTH_PASSWORD=choose-a-password

# Random secret key used for session tokens (letters and numbers)
AUTH_SECRET=some-random-secret-string

# Optional: port the app runs on (default: 3000)
# PORT=3000

# Optional: path to the SQLite database file (default: vastelasten.db in the project folder)
# DB_PATH=vastelasten.db
