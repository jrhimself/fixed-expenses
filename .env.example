# Kopieer dit bestand naar .env en vul de waarden in.

# Wachtwoord om in te loggen in de app
AUTH_PASSWORD=kies-een-wachtwoord

# Willekeurige geheime sleutel voor sessie-tokens (gebruik letters en cijfers)
AUTH_SECRET=willekeurige-geheime-sleutel

# Optioneel: poort waarop de app draait (standaard 3000)
# PORT=3000

# Optioneel: pad naar de SQLite database (standaard: vastelasten.db in de projectmap)
# DB_PATH=vastelasten.db
